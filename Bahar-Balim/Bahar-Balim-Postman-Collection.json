{
  "info": {
    "name": "DupePharma API Collection",
    "description": "Bahar Balım - DupePharma Projesi API Testleri",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://dupe-pharma.vercel.app"
    },
    {
      "key": "token",
      "value": "JWT_TOKEN_BURAYA"
    },
    {
      "key": "productId",
      "value": "69d198c1f8f1315dd9beb1fa"
    },
    {
      "key": "userId",
      "value": "69d1955df8f1315dd9beb1f4"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Üye Olma",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Bahar Balım\",\n  \"email\": \"bahar@123test.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Admin Giriş",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"bahar@123test.com\",\n  \"password\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Ürün Ekle",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CeraVe Nemlendirici Krem\",\n  \"brand\": \"CeraVe\",\n  \"category\": \"nemlendirici\",\n  \"price\": 450,\n  \"description\": \"Cildi yoğun şekilde nemlendiren krem.\",\n  \"ingredients\": [\"Hyaluronic Acid\", \"Ceramide\"],\n  \"usageInstructions\": \"Temiz cilde sabah ve akşam uygulayın.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": ["{{baseUrl}}"],
              "path": ["products"]
            }
          }
        },
        {
          "name": "Ürün Güncelle",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 820,\n  \"description\": \"Güncellenmiş açıklama\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Ürün Sil",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Ürün Detay",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}/details",
              "host": ["{{baseUrl}}"],
              "path": ["products", "{{productId}}", "details"]
            }
          }
        }
      ]
    },
    {
      "name": "AI",
      "item": [
        {
          "name": "AI Ürün Analiz",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/ai/product-analysis",
              "host": ["{{baseUrl}}"],
              "path": ["ai", "product-analysis"]
            }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Şifre Yenileme",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"newPassword\": \"12345678\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/password",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "password"]
            }
          }
        }
      ]
    }
  ]
}
